# The Runt — environment variables
#
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Fill in the values from your Supabase dashboard:
#       Project Settings -> API
# 3. Restart the Expo dev server after editing (npm start).
#
# Note: variables MUST start with EXPO_PUBLIC_ to be visible in the app.
# The anon key is a public client key and is safe to ship.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
